{
  "$schema": "https://schema.railpack.com/railpack-config.json",
  "steps": {
    "install": {
      "cmds": ["npm ci"]
    },
    "build": {
      "dependsOn": ["install"],
      "cmds": ["npm run build"]
    }
  },
  "deploy": {
    "startCmd": "npm run start",
    "variables": {
      "NODE_ENV": "production",
      "PORT": "8080",
      "HOSTNAME": "0.0.0.0"
    }
  }
}
